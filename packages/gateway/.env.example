# 服务
PORT=3100

# Dify
DIFY_BASE_URL=http://localhost:3001
DIFY_API_KEY=
# Per-workflow API keys (导入工作流后从 Dify 控制台获取，见 setup/dify/workflows/README.md)
DIFY_TECH_DOC_API_KEY=
DIFY_OPENAPI_API_KEY=
DIFY_BUG_ANALYSIS_API_KEY=
# Dify RAG 知识库问答（工作流四）
DIFY_RAG_API_KEY=
# Dify Dataset API（知识库文档管理，用于 Wiki.js 自动同步）
DIFY_DATASET_API_KEY=
DIFY_DATASET_ID=

# Plane
PLANE_BASE_URL=http://localhost:80
# 用户浏览器可访问的 Plane 地址（飞书卡片跳转用），未设置则回退到 PLANE_BASE_URL
PLANE_EXTERNAL_URL=
PLANE_API_TOKEN=
PLANE_WORKSPACE_SLUG=
PLANE_DEFAULT_PROJECT_ID=
# Plane 中 "Approved" 状态的 state ID（从 Plane API 或数据库获取）
PLANE_APPROVED_STATE_ID=

# Git
DOCS_GIT_REPO=git@localhost:docs.git
BACKEND_GIT_REPO=git@localhost:backend.git
VUE3_GIT_REPO=git@localhost:vue3.git
FLUTTER_GIT_REPO=git@localhost:flutter.git
ANDROID_GIT_REPO=git@localhost:android.git
GIT_WORK_DIR=/tmp/gateway-git

# Webhook 验签
PLANE_WEBHOOK_SECRET=
GIT_WEBHOOK_SECRET=
CICD_WEBHOOK_SECRET=

# 飞书（私有化部署改为内部域名，如 https://open.xfchat.iflytek.com）
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# 默认飞书群 chat_id，用于工作流通知
FEISHU_DEFAULT_CHAT_ID=

# Wiki.js
WIKIJS_BASE_URL=http://localhost:3000
WIKIJS_API_KEY=

# Claude Code
ANTHROPIC_API_KEY=
CLAUDE_CODE_TIMEOUT=600000

# iBuild CI/CD
IBUILD_BASE_URL=
IBUILD_CLIENT_KEY=
IBUILD_USER=
IBUILD_WEBHOOK_SECRET=
# JSON: appKey → 仓库名映射，如 {"com.example.app":"backend"}
IBUILD_APP_REPO_MAP={"default":"backend"}
