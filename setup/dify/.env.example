# Dify AI 编排平台 环境变量
# 复制为 .env 后修改

# 访问端口
DIFY_WEB_PORT=3001
DIFY_API_PORT=5001
WEAVIATE_PORT=8080

# 安全密钥（务必修改！用 openssl rand -hex 32 生成）
DIFY_SECRET_KEY=change-me-to-a-random-secret
SANDBOX_API_KEY=change-me-sandbox-key
PLUGIN_DAEMON_KEY=change-me-plugin-key
PLUGIN_INNER_API_KEY=change-me-inner-key

# PostgreSQL
DIFY_DB_USER=dify
DIFY_DB_PASSWORD=change-me-db-password
DIFY_DB_NAME=dify
DIFY_PLUGIN_DB=dify_plugin

# Redis（留空表示无密码）
DIFY_REDIS_PASSWORD=

# Weaviate
WEAVIATE_API_KEY=change-me-weaviate-key

# Dify Web 访问配置（必须设置为服务器外部 IP，否则图标等资源会指向 127.0.0.1）
DIFY_CONSOLE_API_URL=http://172.29.230.21:5001
DIFY_APP_API_URL=http://172.29.230.21:5001
FILES_URL=http://172.29.230.21:5001
