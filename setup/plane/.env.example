# Plane CE 环境变量
# 复制为 .env 后修改

# 访问地址（改为服务器 IP 或域名）
APP_DOMAIN=localhost
APP_RELEASE=stable
LISTEN_HTTP_PORT=8082
WEB_URL=http://${APP_DOMAIN}:8082
CORS_ALLOWED_ORIGINS=http://${APP_DOMAIN}:8082

# 安全密钥（务必修改！用 openssl rand -hex 32 生成）
SECRET_KEY=change-me-to-a-random-secret
LIVE_SERVER_SECRET_KEY=change-me-to-a-random-secret

# PostgreSQL
POSTGRES_USER=plane
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=plane

# RabbitMQ
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=change-me-mq-password
RABBITMQ_VHOST=plane

# MinIO（文件存储）
USE_MINIO=1
AWS_ACCESS_KEY_ID=change-me-access-key
AWS_SECRET_ACCESS_KEY=change-me-secret-key
AWS_S3_BUCKET_NAME=uploads
